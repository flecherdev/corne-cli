{
  "name": "corne-cli",
  "version": "0.5.2",
  "description": "CLI tool for customizing Corne keyboards with QMK firmware - Convert GIFs to OLED animations with WPM support and configurable rotation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "corne-cli": "bin/corne-cli.js",
    "corne": "bin/corne-cli.js"
  },
  "scripts": {
    "build": "cross-env NODE_OPTIONS='--no-inspect' tsc",
    "build:watch": "cross-env NODE_OPTIONS='--no-inspect' tsc --watch",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "check": "npm run typecheck && npm run lint",
    "prepublishOnly": "cross-env NODE_OPTIONS='--no-inspect' npm run build"
  },
  "keywords": [
    "corne",
    "keyboard",
    "qmk",
    "firmware",
    "cli",
    "crkbd",
    "split-keyboard",
    "oled",
    "animation",
    "mechanical-keyboard"
  ],
  "author": "flecherdev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flecherdev/corne-cli.git"
  },
  "bugs": {
    "url": "https://github.com/flecherdev/corne-cli/issues"
  },
  "homepage": "https://github.com/flecherdev/corne-cli#readme",
  "dependencies": {
    "ajv": "^8.18.0",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "conf": "^10.2.0",
    "figures": "^3.2.0",
    "inquirer": "^8.2.6",
    "node-hid": "^2.1.2",
    "ora": "^5.4.1",
    "serialport": "^12.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/sharp": "^0.31.1",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "bin/",
    "templates/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "USER_GUIDE.md"
  ]
}
